  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "habit-hooks": "link:../habit-hooks",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.0"
  }
}
